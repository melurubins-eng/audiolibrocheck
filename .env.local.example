# ─────────────────────────────────────────────────────────────────────────────
# Google Cloud Text-to-Speech API Key
# ─────────────────────────────────────────────────────────────────────────────
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un proyecto (o usa uno existente)
# 3. Habilita la API: "Cloud Text-to-Speech API"
# 4. Ve a Credenciales → Crear credencial → Clave de API
# 5. (Opcional) Restringe la clave a la API de TTS por seguridad
# 6. Copia la clave aquí
#
# Free tier: 1M chars/mes con voces Neural2/WaveNet
# Precio: ~$4 USD por 1M chars adicionales con Neural2
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_TTS_API_KEY=tu_api_key_aqui

# ─────────────────────────────────────────────────────────────────────────────
# Límite de caracteres por conversión (default: 200000 ≈ 100 páginas)
# Aumentar para libros más largos (requiere plan de pago en Google TTS)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAX_CHARS=200000
